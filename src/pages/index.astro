---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";

import PricingGrid from "../components/PricingGrid.astro";
import FAQ from "../components/FAQ.astro";
import CTASection from "../components/CTASection.astro";
import ContactSection from "../components/ContactSection.astro";
import Marquee from "../components/Marquee.astro";
import Placeholder from "../components/Placeholder.astro";
import { site, waLink } from "../data/site";
import { journey, whyMembersStay } from "../data/journey";
import { homeFaqs } from "../data/faqs";
import { testimonials_SAMPLE } from "../data/testimonials";
import { reviews_SAMPLE } from "../data/reviews";
import { coaches_SAMPLE } from "../data/coaches";
import { programs } from "../data/programs";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    name: site.name,
    url: site.url,
    telephone: site.phoneHref,
    priceRange: "₹₹",
    address: {
      "@type": "PostalAddress",
      streetAddress: site.address.line1,
      addressLocality: "Example City",
      postalCode: "000001",
      addressCountry: "IN",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: site.address.geo.lat,
      longitude: site.address.geo.lng,
    },
    openingHoursSpecification: {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  },
];
---

<Base
  title="Unicorn Fitness — 24/7 Gym | Free Trial Day"
  description="Real coaching, real equipment, 24/7 access — from ₹32 a day. Claim a free trial day, no card required."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="uf-hero" id="home">
    <!-- z-1: headline (behind athlete) -->
    <div class="uf-hero__headline">
      <h1><span>Stop Starting</span><span class="uf-over">Over.</span></h1>
    </div>

    <!-- z-2: athlete cut-out (transparent PNG) -->
    <div class="uf-hero__figure">
      <picture>
        <source media="(max-width: 768px)" srcset="/assets/img/hero-athlete-mobile.webp" type="image/webp" />
        <source media="(max-width: 768px)" srcset="/assets/img/hero-athlete-mobile.png" />
        <img src="/assets/img/hero-athlete.png" alt="Athlete mid-workout" width="2752" height="1536" fetchpriority="high" />
      </picture>
    </div>

    <!-- z-3: sub-headline + CTAs (in front of athlete) -->
    <div class="uf-hero__copy">
      <div class="uf-hero__copy-inner">
        <p class="uf-hero__lead">Just <strong>₹32 a day</strong> — real coaching, real equipment, and a floor that's open 24/7.</p>
        <div class="uf-hero__actions">
          <a class="uf-hero__btn" href={waLink("Hi Unicorn Fitness! I'd like to claim my free trial day.")} target="_blank" rel="noopener"><i class="fa-solid fa-arrow-right"></i> Claim Your Free Trial Day</a>
          <a class="uf-hero__link" href={waLink("Hi Unicorn Fitness! I'd like to book a gym tour.")} target="_blank" rel="noopener">Book a Gym Tour <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="uf-hero__fine">No card required. No pressure to join.</div>
      </div>
    </div>
  </section>

  <!-- OFFERS TICKER -->
  <Marquee />

  <!-- WHY US -->
  <Section alt bordered>
    <div class="split">
      <div class="split__img reveal">
        <img src="/assets/img/why-us-coach.png" alt="Head coach on the floor, mid-conversation with a member" width="800" height="1000" loading="lazy" />
      </div>
      <div class="reveal">
        <Eyebrow>Why Unicorn</Eyebrow>
        <h2 class="h-section" style="margin-top: var(--space-4); margin-bottom: var(--space-6);">
          We Don't Hand You A Keycard And Disappear.
        </h2>
        <div style="display:flex; flex-direction:column; gap: var(--space-4);">
          <p class="lead">Every member starts with a proper assessment and a plan. You'll never wonder what to do next.</p>
          <p class="lead">Our coaches are on the floor, not hidden in an office — ask anything, any time you train.</p>
          <p class="lead">Honest pricing: one yearly fee, no upsells, no surprises.</p>
        </div>
        <a href="/coaches" class="btn--text" style="margin-top: var(--space-6); display:inline-block;">Meet the coaches →</a>
      </div>
    </div>
  </Section>

  <!-- SOCIAL PROOF: testimonials + reviews strip (sample data — see data/testimonials.js, data/reviews.js) -->
  <Section bordered>
    <div style="text-align:center; margin-bottom: var(--space-12);">
      <Eyebrow>What Members Say</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Don't Take Our Word For It.</h2>
    </div>

    <div class="reveal" style="text-align:center; margin-bottom: var(--space-10);">
      <span class="h-display" style="font-size: 32px; color: var(--accent);">{reviews_SAMPLE.aggregate.rating || "…"}</span>
      <span class="body-sm" style="color: var(--mute); margin-left: var(--space-2);">
        from {reviews_SAMPLE.aggregate.count || "…"} reviews (sample data)
      </span>
    </div>

    <div class="card-grid">
      {testimonials_SAMPLE.map((t) => (
        <div class="card reveal">
          <Placeholder label={t.photoLabel} />
          <p class="lead" style="margin-top: var(--space-5);">{t.quote}</p>
          <p class="body-sm" style="margin-top: var(--space-4); color: var(--mute);">{t.name} — {t.detail}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- TWO PILLARS -->
  <Section bordered>
    <div class="pillars">
      <div class="pillar reveal">
        <div class="pillar__bg">
          <img src="/assets/img/pillar-personal-training.png" alt="Coach spotting a member on a lift" width="800" height="600" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
        </div>
        <a href="/personal-training" class="pillar__link" aria-label="Explore Personal Training"></a>
        <div class="pillar__body">
          <h3 class="h-sub pillar__title">1 On 1 Personal Training</h3>
          <p class="lead" style="margin-bottom: var(--space-4);">A plan built for your body, your schedule, your goal.</p>
          <span class="btn--text">Explore Personal Training →</span>
        </div>
      </div>
      <div class="pillar reveal">
        <div class="pillar__bg">
          <img src="/assets/img/pillar-open-access.png" alt="Empty gym floor at night, lights on" width="800" height="600" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
        </div>
        <a href="/the-gym" class="pillar__link" aria-label="See the facility"></a>
        <div class="pillar__body">
          <h3 class="h-sub pillar__title">24/7 Open Access</h3>
          <p class="lead" style="margin-bottom: var(--space-4);">5 AM or midnight — the door opens for you.</p>
          <span class="btn--text">See the facility →</span>
        </div>
      </div>
    </div>
  </Section>

  <!-- THE PLAN -->
  <Section alt bordered>
    <div style="text-align:center; margin-bottom: var(--space-16);">
      <Eyebrow>Getting Started</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Three Steps. That's It.</h2>
    </div>
    <div class="steps">
      <div class="reveal">
        <div class="step__num">01</div>
        <p class="step__title">Come in for a free day.</p>
        <p class="step__body">Train, look around, ask anything. No sales pitch.</p>
      </div>
      <div class="reveal">
        <div class="step__num">02</div>
        <p class="step__title">Get your starting plan.</p>
        <p class="step__body">A coach assesses you and maps your first four weeks.</p>
      </div>
      <div class="reveal">
        <div class="step__num">03</div>
        <p class="step__title">Show up. We handle the rest.</p>
        <p class="step__body">24/7 access plus coaching whenever you need it.</p>
      </div>
    </div>
    <div style="text-align:center; margin-top: var(--space-12);">
      <Button href="/contact" variant="primary" size="lg">Start With Step 1 — It's Free</Button>
    </div>
  </Section>

  <!-- YOUR FIRST 90 DAYS -->
  <Section bordered class="journey-pin">
    <div style="margin-bottom: var(--space-10);">
      <Eyebrow>What Happens Next</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Here's Exactly What Happens.</h2>
    </div>
    <div class="carousel__viewport">
      <div class="carousel">
        {journey.map((step, i) => (
          <div class="carousel__card">
            <figure class="carousel__figure">
              <img
                src={`/assets/img/journey-${['day1','week1','month1','month3'][i]}.png`}
                alt={`${step.tag} — ${step.sub}`}
                width="400"
                height="400"
                loading="lazy"
              />
            </figure>
            <div class="carousel__body">
              <p class="h-display carousel__name">{step.tag}</p>
              <p class="carousel__sub mono">{step.sub}</p>
              <p class="carousel__result">{step.result}</p>
              <p class="carousel__quote">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- MEET THE COACHES (teaser) -->
  <Section alt bordered>
    <div style="text-align:center; margin-bottom: var(--space-16);">
      <Eyebrow>The Coaches</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">You'll Know Your Coach's Name.</h2>
    </div>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-8);">
      {coaches_SAMPLE.slice(0, 3).map((coach) => (
        <div class="card reveal" style="display:flex; flex-direction:column; gap: var(--space-5);">
          <Placeholder label={coach.photoLabel} />
          <div>
            <p class="card__title">{coach.name}</p>
            <p class="body-sm" style="color: var(--accent); margin-top: var(--space-1);">{coach.role}</p>
          </div>
        </div>
      ))}
    </div>
    <div style="text-align:center; margin-top: var(--space-12);">
      <a href="/coaches" class="btn--text">Meet all our coaches →</a>
    </div>
  </Section>

  <!-- WHY MEMBERS STAY (replaces the earlier brand-new-gym-framed band) -->
  <Section bordered>
    <div style="text-align:center; margin-bottom: var(--space-16);">
      <Eyebrow>Membership</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Why Members Stick Around.</h2>
    </div>
    <div class="card-grid">
      {whyMembersStay.map((item) => (
        <div class="card reveal">
          <p class="card__title">{item.title}</p>
          <p class="body-sm">{item.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- WHAT WE OFFER (programs band) -->
  <Section alt bordered>
    <div style="text-align:center; margin-bottom: var(--space-16);">
      <Eyebrow>Programs</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Pick What You're Training For.</h2>
    </div>
    <div class="card-grid">
      {programs.map((program) => (
        <div class="card reveal">
          <p class="card__title">{program.title}</p>
          <p class="body-sm" style="margin-top: var(--space-3);">{program.description}</p>
        </div>
      ))}
    </div>
    <div style="text-align:center; margin-top: var(--space-12);">
      <a href="/personal-training" class="btn--text">See all programs →</a>
    </div>
  </Section>

  <!-- PRICING -->
  <Section bordered>
    <div style="text-align:center; margin-bottom: var(--space-12);">
      <Eyebrow>Membership</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4);">Same Access. Your Timeline.</h2>
    </div>
    <PricingGrid showFoot />
    <p class="body-sm reveal" style="text-align:center; margin-top: var(--space-6); color: var(--ash);">
      Same coaching, same access, at every length — pick the timeline that suits your budget.
      <a href="/membership" class="btn--text">See full details →</a>
    </p>
  </Section>

  <!-- FAQ -->
  <Section alt bordered>
    <div style="text-align:center; margin-bottom: var(--space-12);">
      <h2 class="h-section reveal">Questions, Answered.</h2>
    </div>
    <div style="max-width: 800px; margin-inline: auto;">
      <FAQ items={homeFaqs} />
    </div>
  </Section>

  <!-- FINAL CTA -->
  <CTASection heading="Everyone You Admire Started On Day One." />

  <!-- CONTACT -->
  <ContactSection />
</Base>
