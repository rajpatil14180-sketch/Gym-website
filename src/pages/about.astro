---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import PageHero from "../components/PageHero.astro";

import StatCounter from "../components/StatCounter.astro";
import CTASection from "../components/CTASection.astro";
import { trustStats } from "../data/journey";
---

<Base
  title="About Us — Unicorn Fitness"
  description="Why Unicorn Fitness exists, how we coach, and who you'll train with. Open 24/7."
>
  <PageHero
    eyebrow="About Us"
    title="We Opened So You'd Stop Starting Over."
    subhead="Most gyms hand you a keycard and hope you figure it out. We built Unicorn differently — coaching included, not sold as an upsell."
  />

  <Section>
    <div class="split">
      <div class="split__img reveal">
        <img src="/assets/img/about-hero.png" alt="Head coach walking a new member through their first session" width="800" height="1000" loading="lazy" />
      </div>
      <div class="reveal">
        <Eyebrow>Why We Started</Eyebrow>
        <h2 class="h-section" style="margin-top: var(--space-4); margin-bottom: var(--space-6);">
          A Gym Built Around Coaching, Not Just Equipment.
        </h2>
        <div style="display:flex; flex-direction:column; gap: var(--space-4);">
          <p class="lead">
            Anyone can put a rack of dumbbells in a room. What most gyms skip is the part that actually keeps
            people coming back — someone on the floor who knows your name, your goal, and where you're stuck.
          </p>
          <p class="lead">
            So that's what we built first. Every member starts with a real assessment and a plan, not a
            keycard and a shrug.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section alt bordered tight>
    <div class="stat-bar">
      {trustStats.map((stat) => (
        <StatCounter value={stat.value} label={stat.label} suffix={stat.suffix} />
      ))}
    </div>
  </Section>

  <!-- Full coach roster now lives on /coaches — this is a short teaser only. -->
  <Section bordered>
    <div style="text-align:center;">
      <Eyebrow>The Coaches</Eyebrow>
      <h2 class="h-section reveal" style="margin-top: var(--space-4); margin-bottom: var(--space-6);">
        Who You'll Actually Train With.
      </h2>
      <p class="lead reveal" style="max-width: 600px; margin-inline: auto;">
        Every coach here is certified, on the floor every day, and easy to find when you need them.
      </p>
      <a href="/coaches" class="btn--text" style="margin-top: var(--space-6); display:inline-block;">
        Meet all our coaches →
      </a>
    </div>
  </Section>

  <CTASection heading="Come Meet The Coaches Yourself." tagline="First day's free." />
</Base>
