---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Eyebrow from "../components/Eyebrow.astro";
import PageHero from "../components/PageHero.astro";
import Placeholder from "../components/Placeholder.astro";
import StatCounter from "../components/StatCounter.astro";
import CTASection from "../components/CTASection.astro";
import { trainers } from "../data/trainers";
import { trustStats } from "../data/journey";

// trainers.js ships with TODO placeholders until the owner supplies real
// coach info — never show raw "TODO:" text to site visitors.
const realTrainers = trainers.filter((t) => !t.name.startsWith("TODO"));
---

<Base
  title="About Us — Unicorn Fitness"
  description="Why Unicorn Fitness exists, how we coach, and who you'll train with. 24/7 gym in Ghansoli, Navi Mumbai."
>
  <PageHero
    eyebrow="About Us"
    title="We Opened So You'd Stop Starting Over."
    subhead="Most gyms hand you a keycard and hope you figure it out. We built Unicorn differently — coaching included, not sold as an upsell."
  />

  <Section>
    <div class="split">
      <Placeholder label="Head coach on the floor, walking a new member through their first session" class="reveal" />
      <div class="reveal">
        <Eyebrow>Why We Started</Eyebrow>
        <h2 class="h-section" style="margin-top: var(--space-4); margin-bottom: var(--space-6);">
          A Gym Built Around Coaching, Not Just Equipment.
        </h2>
        <div style="display:flex; flex-direction:column; gap: var(--space-4);">
          <p class="lead">
            Anyone can put a rack of dumbbells in a room. What most gyms skip is the part that actually keeps
            people coming back — someone on the floor who knows your name, your goal, and where you're stuck.
          </p>
          <p class="lead">
            So that's what we built first. Every member starts with a real assessment and a plan, not a
            keycard and a shrug.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section alt bordered tight>
    <div class="stat-bar">
      {trustStats.map((stat) => (
        <StatCounter value={stat.value} label={stat.label} suffix={stat.suffix} />
      ))}
    </div>
  </Section>

  {realTrainers.length > 0 && (
    <Section bordered>
      <div style="text-align:center; margin-bottom: var(--space-16);">
        <Eyebrow>The Coaches</Eyebrow>
        <h2 class="h-section reveal" style="margin-top: var(--space-4);">Who You'll Actually Train With.</h2>
      </div>
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-8);">
        {realTrainers.map((trainer) => (
          <div class="card reveal" style="display:flex; flex-direction:column; gap: var(--space-5);">
            <Placeholder label={trainer.role ? `Portrait of ${trainer.name}, ${trainer.role}` : `Portrait of ${trainer.name}`} />
            <div>
              <p class="card__title">{trainer.name}</p>
              {trainer.role && (
                <p class="body-sm" style="color: var(--accent); margin-top: var(--space-1);">{trainer.role}</p>
              )}
              <p class="body-sm" style="margin-top: var(--space-3);">{trainer.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </Section>
  )}

  <CTASection heading="Come Meet The Coaches Yourself." tagline="First day's free." />
</Base>
