---
interface Props {
  href?: string;
  variant?: "primary" | "ghost" | "text" | "whatsapp";
  size?: "md" | "lg";
  block?: boolean;
  class?: string;
  icon?: string; // font-awesome class
  type?: "button" | "submit";
}

const {
  href,
  variant = "primary",
  size = "md",
  block = false,
  class: className = "",
  icon,
  type = "button",
} = Astro.props;

const classes = [
  "btn",
  `btn--${variant}`,
  size === "lg" ? "btn--lg" : "",
  block ? "btn--block" : "",
  className,
]
  .filter(Boolean)
  .join(" ");

const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} type={href ? undefined : type}>
  {icon && <i class={icon} aria-hidden="true"></i>}
  <slot />
</Tag>
